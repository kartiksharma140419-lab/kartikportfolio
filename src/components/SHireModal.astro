---

---

<div class="hire-modal js-hire-modal" aria-hidden="true" style="display: none;">
  <div class="hire-modal__backdrop js-hire-backdrop"></div>
  <div class="hire-modal__card">
    <button
      class="hire-modal__close js-hire-close"
      type="button"
      aria-label="Close form"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <h2 class="hire-modal__title">Apply for Priority<br />Onboarding.</h2>
    <p class="hire-modal__subtitle">
      I only accept 10 high-impact projects per month to ensure elite quality.
      Secure your slot in the queue below.
    </p>

    <div class="hire-modal__gauge js-gauge-container">
      <div class="hire-modal__gauge-fill js-gauge-fill"></div>
      <p class="hire-modal__gauge-text">
        <span class="js-gauge-text">0%</span> Application Strength
      </p>
    </div>

    <div class="hire-modal__urgency js-hire-urgency">
      <span class="pulse"></span> Limited slots left for making your business website,
      app, or landing page.
    </div>

    <form
      class="hire-modal__form js-hire-form"
      action="https://api.web3forms.com/submit"
      method="POST"
    >
      <input
        type="hidden"
        name="access_key"
        value="daa4c037-78d3-4074-a324-07a29462c91f"
      />

      <div class="hf__field">
        <input
          type="text"
          name="business_owner_name"
          id="modal-owner"
          placeholder=" "
          required
        />
        <label for="modal-owner">Owner's Name?</label>
      </div>

      <div class="hf__field">
        <input
          type="tel"
          name="owner_mobile"
          id="modal-mobile"
          placeholder=" "
          required
        />
        <label for="modal-mobile">Owner's Mobile Number</label>
      </div>

      <div class="hf__field hf__field--full">
        <input
          type="email"
          name="email"
          id="modal-email"
          placeholder=" "
          required
          inputmode="email"
        />
        <label for="modal-email">Professional Email</label>
      </div>

      <div class="hf__field hf__field--full">
        <input
          type="text"
          name="business_name"
          id="modal-biz"
          placeholder=" "
          required
        />
        <label for="modal-biz">Company / Project Name</label>
      </div>

      <div class="hf__field">
        <input
          type="text"
          name="business_type"
          id="modal-type"
          placeholder=" "
          required
        />
        <label for="modal-type">Industry (e.g. SaaS, E-com)</label>
      </div>

      <div class="hf__field">
        <input
          type="text"
          name="partner_code"
          id="modal-code"
          placeholder=" "
          class="js-hire-code"
        />
        <label for="modal-code">Exclusive Partner Code (Optional)</label>
        <p class="hf__field-error js-hire-code-error" style="display: none;">
          Not a valid coupon code
        </p>
        <p class="hf__field-timer">
          Coupon code valid for: <span class="js-countdown-timer">
            23:59:59
          </span>
        </p>
      </div>

      <div class="hf__field hf__field--select hf__field--full">
        <select name="budget" id="modal-budget" class="js-hire-budget" required>
          <option value="" disabled selected></option>
          <option value="₹20,000" data-original="₹20,000">Starter (₹20,000)</option>
          <option value="₹35,000" data-original="₹35,000">
            Pro / Bestseller (₹35,000)
          </option>
          <option value="₹50,000" data-original="₹50,000">Scale (₹50,000)</option>
          <option value="₹90,000" data-original="₹90,000">Enterprise (₹90,000+)</option>
        </select>
        <label for="modal-budget">Estimated Investment</label>
        <div class="hf__field-discount js-hire-discount-display" style="display: none;"></div>
      </div>

      <div class="hf__field hf__field--full">
        <textarea
          name="more_info"
          id="modal-info"
          placeholder=" "
          rows="3"
          required
        >
        </textarea>
        <label for="modal-info">Describe your growth goals & timelines</label>
      </div>

      <div class="hf__field hf__field--full hf__field--submit">
        <button type="submit" class="hire-modal__submit js-hire-submit">
          <span>Apply for Business Growth</span>
          <svg
            class="h-arrow"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
        <p class="hire-modal__trust">
          🔒 100% Secure. We never share your data.
        </p>
      </div>
    </form>

    <div class="hire-modal__success js-hire-success" style="display:none;">
      <svg
        width="56"
        height="56"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-success-icon"
      >
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
        <polyline points="22 4 12 14.01 9 11.01"></polyline>
      </svg>
      <h3 class="h-success-title">Thank You!</h3>
      <p class="h-success-text">Our team will reach out within 24 hours.</p>
    </div>
  </div><!-- .hire-modal__card -->
</div><!-- .hire-modal -->

<script>
  import { gsap } from 'gsap'
  import confetti from 'canvas-confetti'
  import BaseSection from '../utils/BaseSection'
  import config from '../data/config.json'

  class Section extends BaseSection {
    backdrop: HTMLElement
    card: HTMLElement
    closeBtns: NodeListOf<Element>
    openBtns: NodeListOf<Element>
    form: HTMLFormElement
    success: HTMLElement
    submitBtn: HTMLButtonElement
    inputs: NodeListOf<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>
    gaugeFill: HTMLElement
    gaugeText: HTMLElement
    timerDisplay: HTMLElement
    codeInput: HTMLInputElement
    budgetSelect: HTMLSelectElement
    hireCodeError: HTMLElement
    hireDiscountDisplay: HTMLElement

    timeRemaining: number = config.urgency.countdownSeconds
    isUnlockedState: boolean = false
    isOpen: boolean = false

    validCodes: string[] = config.pricing.validCodes
    valMap: Record<string, { price: string; pct: string; label: string }> = config.pricing.tiers

    constructor() {
      super('.js-hire-modal')

      this.backdrop = this.el.querySelector('.js-hire-backdrop')
      this.card = this.el.querySelector('.hire-modal__card')
      this.closeBtns = document.querySelectorAll('.js-hire-close')
      this.openBtns = document.querySelectorAll('.js-hire-me')
      this.form = this.el.querySelector('.js-hire-form')
      this.success = this.el.querySelector('.js-hire-success')
      this.submitBtn = this.el.querySelector('.js-hire-submit')
      this.inputs = this.form?.querySelectorAll('input[required], select[required], textarea[required]')
      this.gaugeFill = this.el.querySelector('.js-gauge-fill')
      this.gaugeText = this.el.querySelector('.js-gauge-text')
      this.timerDisplay = this.el.querySelector('.js-countdown-timer')
      this.codeInput = this.el.querySelector('.js-hire-code')
      this.budgetSelect = this.el.querySelector('.js-hire-budget')
      this.hireCodeError = this.el.querySelector('.js-hire-code-error')
      this.hireDiscountDisplay = this.el.querySelector('.js-hire-discount-display')
    }

    init() {
      this.updateTimer()
      setInterval(() => this.updateTimer(), 1000)
      super.init()
    }

    bindBaseEvents() {
      super.bindBaseEvents()
      this.openBtns.forEach((btn) => btn.addEventListener('click', (e) => this.openModal(e)))
      this.closeBtns.forEach((btn) => btn.addEventListener('click', (e) => this.closeModal(e)))
      this.backdrop?.addEventListener('click', (e) => this.closeModal(e))
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.isOpen) this.closeModal()
      })

      this.inputs?.forEach((input) => {
        input.addEventListener('input', () => this.updateGauge())
        input.addEventListener('change', () => this.updateGauge())
      })

      this.codeInput?.addEventListener('input', (e) => this.onCodeInput(e))
      this.budgetSelect?.addEventListener('change', (e) => this.onBudgetChange(e))
      this.form?.addEventListener('submit', (e) => this.onFormSubmit(e))
    }

    updateGauge() {
      if (!this.inputs?.length) return
      let filled = 0
      this.inputs.forEach((input) => {
        if (input.value.trim() !== '') filled++
      })
      const percentage = Math.round((filled / this.inputs.length) * 100)
      if (this.gaugeFill) {
        this.gaugeFill.style.width = `${percentage}%`
        this.gaugeFill.style.background = percentage === 100 ? '#10b981' : 'var(--color-primary, #f40c3f)'
      }
      if (this.gaugeText) this.gaugeText.textContent = `${percentage}%`
    }

    updateTimer() {
      if (!this.timerDisplay) return
      const hours = Math.floor(this.timeRemaining / 3600)
      const minutes = Math.floor((this.timeRemaining % 3600) / 60)
      const seconds = this.timeRemaining % 60
      this.timerDisplay.textContent = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`
      if (this.timeRemaining > 0) this.timeRemaining--
    }

    strike(str: string) {
      return str.split('').map((char) => char + '\u0336').join('')
    }

    onCodeInput(e: Event) {
      const val = (e.target as HTMLInputElement).value.trim().toUpperCase()
      if (this.validCodes.includes(val)) {
        if (this.hireCodeError) this.hireCodeError.style.display = 'none'
        if (!this.isUnlockedState) {
          this.isUnlockedState = true
          confetti({
            particleCount: 150,
            spread: 100,
            origin: { y: 0.5 },
            colors: ['#10b981', '#fbbf24', '#ffffff', '#34d399'],
            disableForReducedMotion: true,
          })
          this.card.classList.add('is-unlocked')
          this.submitBtn.querySelector('span')!.textContent = 'Claim My Exclusive Slot'
          this.submitBtn.classList.add('is-unlocked-btn')
        }

        Array.from(this.budgetSelect.options).forEach((opt) => {
          const orig = opt.getAttribute('data-original')
          if (orig && this.valMap[orig]) {
            const d = this.valMap[orig]
            opt.innerHTML = `${d.label} ${this.strike(orig)} → ${d.price} (${d.pct})`
            opt.value = `${orig} → ${d.price} (${d.pct})`
          }
        })
        this.budgetSelect.classList.add('has-discount')
      } else {
        if (this.hireCodeError) this.hireCodeError.style.display = val.length > 0 ? 'block' : 'none'
        if (this.isUnlockedState) {
          this.isUnlockedState = false
          this.card.classList.remove('is-unlocked')
          this.submitBtn.querySelector('span')!.textContent = 'Apply for Business Growth'
          this.submitBtn.classList.remove('is-unlocked-btn')
        }

        Array.from(this.budgetSelect.options).forEach((opt) => {
          const orig = opt.getAttribute('data-original')
          if (orig && this.valMap[orig]) {
            opt.innerHTML = `${this.valMap[orig].label} (${orig})`
            opt.value = orig
          } else if (orig === '₹90,000') {
            opt.innerHTML = 'Enterprise (₹90,000+)'
            opt.value = orig
          }
        })
        this.budgetSelect.classList.remove('has-discount')
      }
      this.updateDiscountDisplay()
    }

    onBudgetChange(e: Event) {
      const val = (e.target as HTMLSelectElement).value
      this.budgetSelect.classList.toggle('has-discount-selected', val.includes('OFF'))
      this.updateDiscountDisplay()
    }

    updateDiscountDisplay() {
      const codeVal = this.codeInput.value.trim().toUpperCase()
      const selectedOrig = this.budgetSelect.options[this.budgetSelect.selectedIndex]?.getAttribute('data-original')
      
      if (this.validCodes.includes(codeVal) && selectedOrig && this.valMap[selectedOrig]) {
        const data = this.valMap[selectedOrig]
        if (this.hireDiscountDisplay) {
          this.hireDiscountDisplay.innerHTML = `
            <span class="hf__field-discount__old">${selectedOrig}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            <span class="hf__field-discount__new">${data.price}</span>
            <span class="hf__field-discount__pct">(${data.pct})</span>
          `
          this.hireDiscountDisplay.style.display = 'flex'
          setTimeout(() => this.hireDiscountDisplay.classList.add('is-visible'), 10)
        }
      } else if (this.hireDiscountDisplay) {
        this.hireDiscountDisplay.classList.remove('is-visible')
        setTimeout(() => {
          if (!this.hireDiscountDisplay.classList.contains('is-visible')) {
            this.hireDiscountDisplay.style.display = 'none'
          }
        }, 300)
      }
    }

    openModal(e: Event) {
      e.preventDefault()
      if (this.isOpen) return
      this.isOpen = true

      this.el.style.display = 'flex'
      this.el.setAttribute('aria-hidden', 'false')
      document.documentElement.style.overflow = 'hidden'

      gsap.fromTo(this.backdrop, { opacity: 0 }, { opacity: 1, duration: 0.5, ease: 'power3.inOut' })
      gsap.fromTo(this.card, { y: 50, opacity: 0, scale: 0.95 }, { y: 0, opacity: 1, scale: 1, duration: 0.5, ease: 'power3.inOut' })
    }

    closeModal(e?: Event) {
      if (e) e.preventDefault()
      if (!this.isOpen) return
      this.isOpen = false

      document.documentElement.style.overflow = ''

      gsap.to(this.backdrop, { opacity: 0, duration: 0.5, ease: 'power3.inOut' })
      gsap.to(this.card, {
        y: 20,
        opacity: 0,
        scale: 0.95,
        duration: 0.5,
        ease: 'power3.inOut',
        onComplete: () => {
          this.el.setAttribute('aria-hidden', 'true')
          this.el.style.display = 'none'
        },
      })
    }

    async onFormSubmit(e: Event) {
      e.preventDefault()
      this.submitBtn.disabled = true
      this.submitBtn.classList.add('is-loading')
      this.submitBtn.querySelector('span')!.textContent = 'Sending...'

      try {
        const formData = new FormData(this.form)
        const res = await fetch(this.form.action, { method: 'POST', body: formData })
        const data = await res.json()

        if (data.success) {
          this.form.style.display = 'none'
          this.success.style.display = 'flex'
          gsap.fromTo(this.success, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.5, ease: 'power3.inOut' })
        } else {
          this.resetSubmitBtn()
          alert('Something went wrong. Please try again.')
        }
      } catch (err) {
        this.resetSubmitBtn()
        alert('Network error. Please check your connection and try again.')
      }
    }

    resetSubmitBtn() {
      this.submitBtn.disabled = false
      this.submitBtn.classList.remove('is-loading')
      this.submitBtn.querySelector('span')!.textContent = this.isUnlockedState ? 'Claim My Exclusive Slot' : 'Apply for Business Growth'
    }
  }

  new Section()
</script>

<style lang="scss">
  .hire-modal {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 1000;

    display: flex;
    align-items: center;
    justify-content: center;

    width: 100%;
    height: 100%;

    &__backdrop {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      cursor: pointer;
    }

    &__card {
      position: relative;
      z-index: 2;

      width: 90%;
      max-width: 38rem;
      max-height: 90vh;
      padding: 3.5rem 3rem 3rem;

      background: rgba(22, 0, 0, 0.7);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255, 242, 237, 0.1);
      border-radius: 1.25rem;

      overflow-y: auto;
      transition:
        box-shadow 0.5s ease,
        border-color 0.5s ease;

      // hide scrollbar completely
      -ms-overflow-style: none;
      scrollbar-width: none;
      &::-webkit-scrollbar {
        display: none;
      }

      &.is-unlocked {
        border-color: rgba(251, 191, 36, 0.4); // Gold tint
        animation:
          premium-unlock 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards,
          pulse-glow 3s infinite 0.6s;

        .theme-contrasted & {
          border-color: rgba(251, 191, 36, 0.5);
        }
      }

      .theme-contrasted & {
        background: rgba(255, 255, 255, 0.85);
        border-color: rgba(22, 0, 0, 0.1);
      }

      @include mq(phone) {
        padding: 3rem 1.5rem 2rem;
        max-height: 95vh;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
        background: rgba(22, 0, 0, 0.98);
      }
    }

    &__close {
      position: absolute;
      top: 1.5rem;
      right: 1.5rem;

      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.5rem;
      height: 2.5rem;

      background: rgba(255, 242, 237, 0.05);
      border: 1px solid rgba(255, 242, 237, 0.1);
      border-radius: 50%;
      color: rgba(255, 242, 237, 0.7);
      cursor: pointer;

      transition: all 0.3s ease;

      .theme-contrasted & {
        background: rgba(22, 0, 0, 0.05);
        border-color: rgba(22, 0, 0, 0.1);
        color: rgba(22, 0, 0, 0.7);
      }

      &:hover {
        background: rgba(255, 242, 237, 0.1);
        color: var(--color-primary);

        .theme-contrasted & {
          background: rgba(22, 0, 0, 0.1);
          color: color(secondary);
        }
      }
    }

    &__title {
      margin: 0 0 1rem;
      color: var(--color-primary);
      font: 700 clamp(1.75rem, 3vw, 2.25rem) / 1.15 font-family(editorial);

      .theme-contrasted & {
        color: color(secondary);
      }
    }

    &__subtitle {
      margin: 0 0 1.5rem;
      color: rgba(255, 242, 237, 0.7);
      font: 400 clamp(0.875rem, 1.25vw, 1.1rem) / 1.6 font-family(editorial);

      .theme-contrasted & {
        color: rgba(22, 0, 0, 0.65);
      }

      @include mq(phone) {
        margin-bottom: 1.25rem;
      }
    }

    &__urgency {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 2rem;
      padding: 0.75rem 1rem;
      background: rgba(244, 12, 63, 0.08); // Primary color tint
      border: 1px solid rgba(244, 12, 63, 0.15);
      border-radius: 0.5rem;
      color: rgba(255, 242, 237, 0.85);
      font: 400 0.875rem / 1.4 font-family(editorial);

      .theme-contrasted & {
        background: rgba(22, 0, 0, 0.04);
        border-color: rgba(22, 0, 0, 0.1);
        color: rgba(22, 0, 0, 0.85);
      }

      .pulse {
        display: inline-block;
        width: 8px;
        height: 8px;
        background: var(--color-primary);
        border-radius: 50%;
        box-shadow: 0 0 0 rgba(244, 12, 63, 0.4);
        animation: pulse-dot 2s infinite;

        .theme-contrasted & {
          background: color(secondary);
          box-shadow: 0 0 0 rgba(22, 0, 0, 0.4);
        }
      }
    }

    &__gauge {
      width: 100%;
      height: 6px;
      background: rgba(255, 242, 237, 0.1);
      border-radius: 3px;
      margin-bottom: 2rem;
      position: relative;
      overflow: hidden;

      .theme-contrasted & {
        background: rgba(22, 0, 0, 0.1);
      }

      &-fill {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        width: 0%;
        background: var(--color-primary);
        border-radius: 3px;
        transition:
          width 0.4s cubic-bezier(0.22, 1, 0.36, 1),
          background-color 0.4s ease;

        .theme-contrasted & {
          background: color(secondary);
        }
      }

      &-text {
        position: absolute;
        top: -24px; // moved up to prevent overlapping the progress bar
        right: 0;
        font: 400 0.75rem / 1 font-family(fraktion);
        color: rgba(255, 242, 237, 0.6);
        text-transform: uppercase;
        letter-spacing: 0.05em;

        .theme-contrasted & {
          color: rgba(22, 0, 0, 0.6);
        }

        span {
          font-weight: 700;
          color: rgba(255, 242, 237, 0.9);

          .theme-contrasted & {
            color: rgba(22, 0, 0, 0.9);
          }
        }
      }
    }

    &__form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem 1rem;

      @include mq(phone) {
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }
    }

    .hf__field {
      position: relative;

      &--full {
        grid-column: 1 / -1;
      }

      &--submit {
        margin-top: 0.5rem;
      }

      label {
        position: absolute;
        top: 1rem;
        left: 1rem;

        color: rgba(255, 242, 237, 0.45);
        font: 400 0.8125rem / 1 font-family(fraktion);
        letter-spacing: 0.03em;
        text-transform: uppercase;

        pointer-events: none;
        transform-origin: 0 0;
        transition:
          transform 0.25s cubic-bezier(0.25, 1, 0.5, 1),
          color 0.25s ease;

        .theme-contrasted & {
          color: rgba(22, 0, 0, 0.45);
        }
      }

      input,
      select,
      textarea {
        display: block;
        width: 100%;
        padding: 1.65rem 1rem 0.6rem;

        background: rgba(255, 242, 237, 0.04);
        border: 1px solid rgba(255, 242, 237, 0.12);
        border-radius: 0.5rem;

        color: rgba(255, 242, 237, 0.95);
        font: 400 0.9375rem / 1.5 font-family(editorial);

        outline: none;
        transition:
          border-color 0.3s ease,
          box-shadow 0.3s ease;

        .theme-contrasted & {
          background: rgba(22, 0, 0, 0.04);
          border-color: rgba(22, 0, 0, 0.15);
          color: rgba(22, 0, 0, 0.9);
        }

        &:focus {
          border-color: var(--color-primary);
          box-shadow: 0 0 0 3px rgba(244, 12, 63, 0.15);

          .theme-contrasted & {
            border-color: color(secondary);
            box-shadow: 0 0 0 3px rgba(22, 0, 0, 0.1);
          }
        }

        &:focus + label,
        &:not(:placeholder-shown) + label {
          transform: translateY(-0.55rem) scale(0.75);
          color: var(--color-primary);

          .theme-contrasted & {
            color: color(secondary);
          }
        }
      }

      @include mq(phone-sm) {
        input,
        select,
        textarea {
