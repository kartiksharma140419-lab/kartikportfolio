---

<section id="business-advantage" class="s-business" data-intersect>
  <div class="s__inner">
    <h2 class="s__title">The Business Advantage</h2>

    <div class="s__grid">
      <!-- Item 1 -->
      <div class="s__item" data-intersect="fade-up">
        <div class="s__icon">
          <!-- Lightning -->
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            class="a__svg"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </path>
          </svg>
        </div>
        <h3 class="s__item-title">Performance Infra</h3>
        <p class="s__item-text">
          Ultra-fast, zero-friction loading to ensure no customer is lost to
          lag.
        </p>
      </div>

      <!-- Item 2 -->
      <div class="s__item" data-intersect="fade-up">
        <div class="s__icon">
          <!-- Gear -->
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            class="a__svg"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </path>
            <circle
              cx="12"
              cy="12"
              r="3"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </circle>
          </svg>
        </div>
        <h3 class="s__item-title">Automation (n8n)</h3>
        <p class="s__item-text">
          Integrated AI workflows that capture and notify you of leads 24/7.
        </p>
      </div>

      <!-- Item 3 -->
      <div class="s__item" data-intersect="fade-up">
        <div class="s__icon">
          <!-- Growth/Chart -->
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            class="a__svg"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M3 3v18h18"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </path>
            <path
              d="M18 9l-5 5-4-4-5 5"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </path>
            <path
              d="M18 9h-4"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </path>
            <path
              d="M18 9v4"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </path>
          </svg>
        </div>
        <h3 class="s__item-title">ROI-First Design</h3>
        <p class="s__item-text">
          Every pixel is engineered to move the user toward the 'Order' button.
        </p>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .s-business {
    position: relative;
    z-index: 3;

    /* Consistent padding matching SLeadCapture & SAbout principles */
    padding: 8rem 0 4rem;

    @include mq(tablet) {
      padding: 5rem 0 2.5rem;
    }

    @include mq(phone) {
      padding: 3rem 0 1.5rem;
    }
  }

  .s__inner {
    margin: 0 auto;
    max-width: 64rem;
    width: 90%;

    @include mq(tablet) {
      width: 92%;
    }

    @include mq(phone) {
      width: 95%;
    }
  }

  .s__title {
    margin: 0 0 4rem;
    text-align: center;

    color: color(primary);
    font: 700 clamp(1.75rem, 3vw, 2.75rem) / 1.15 font-family(editorial);

    .theme-contrasted & {
      color: color(secondary);
    }

    @include mq(phone) {
      margin-bottom: 2.5rem;
    }
  }

  .s__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;

    @include mq(tablet) {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .s__item {
    background: rgba(22, 0, 0, 0.6);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 242, 237, 0.1);
    border-radius: 1.5rem;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;

    .theme-contrasted & {
      background: color(primary);
      border-color: rgba(22, 0, 0, 0.1);
    }

    &:hover {
      transform: translateY(-5px);
      border-color: var(--color-primary);
    }

    @include mq(phone) {
      padding: 2rem;
      border-radius: 1rem;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: rgba(22, 0, 0, 0.98);

      .theme-contrasted & {
        background: color(primary);
      }
    }
  }

  .s__icon {
    width: 3.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    margin-bottom: 1.5rem;

    /* Match accent colors */
    color: #fff;
    background: var(--color-primary);

    .theme-contrasted & {
      color: color(primary);
      background: color(secondary);
    }

    .a__svg {
      width: 1.75rem;
      height: 1.75rem;
    }
  }

  .s__item-title {
    margin: 0 0 1rem;
    color: rgba(255, 242, 237, 0.95);
    font: 700 1.5rem / 1.2 font-family(editorial);

    .theme-contrasted & {
      color: color(secondary);
    }
  }

  .s__item-text {
    margin: 0;
    color: rgba(255, 242, 237, 0.7);
    font: 400 1rem / 1.6 font-family(editorial);

    .theme-contrasted & {
      color: rgba(22, 0, 0, 0.65);
    }
  }
</style>
